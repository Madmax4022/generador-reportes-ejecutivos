# ========================================
# AutoReport SaaS - Configuración (Fase 1)
# ========================================
#
# La app FUNCIONA SIN CONFIGURAR NADA (modo demo).
# Cuando quieras conectar cuentas reales de Google, rellena los valores
# de abajo. Tú (el operador del SaaS) registras UNA sola app en Google
# Cloud; tus clientes solo hacen clic en "Conectar con Google".

# --- Servidor ---
PORT=4000
# URL pública donde corre el SaaS (en local: http://localhost:4000)
BASE_URL=http://localhost:4000
SESSION_SECRET=cambia_esto_por_un_secret_largo_y_aleatorio

# --- Google OAuth (UNA app para todos tus clientes) ---
# Crear en https://console.cloud.google.com -> Credenciales -> ID de cliente OAuth (Web)
# Redirect URI autorizado: {BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (Fase 3 - facturación, aún no requerido) ---
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID=
